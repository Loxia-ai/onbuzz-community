#!/bin/bash
# OnBuzz Community - Linux Post-installation Script

set -e

INSTALL_DIR="/usr/lib/onbuzz"
BIN_DIR="/usr/bin"

# Create symlink for the onbuzz command
ln -sf "$INSTALL_DIR/onbuzz" "$BIN_DIR/onbuzz"

# Make binary executable
chmod +x "$INSTALL_DIR/onbuzz"

echo "OnBuzz Community installed successfully!"
echo ""
echo "Available commands:"
echo "  onbuzz web        - Start server and open Web UI"
echo "  onbuzz terminal   - Start Terminal UI"
echo "  onbuzz serve      - Start server only (headless)"
echo "  onbuzz --help     - Show all commands"
echo ""
echo "To get started, run: onbuzz web"

exit 0
