#!/bin/bash
# OnBuzz Community - macOS Pre-installation Script

set -e

INSTALL_DIR="/usr/local/lib/onbuzz"
BIN_DIR="/usr/local/bin"

# Remove existing symlink if present
if [ -L "$BIN_DIR/onbuzz" ]; then
    rm -f "$BIN_DIR/onbuzz"
    echo "Removed existing onbuzz symlink"
fi

# Remove old installation if exists
if [ -d "$INSTALL_DIR" ]; then
    rm -rf "$INSTALL_DIR"
    echo "Removed previous installation"
fi

# Create installation directory
mkdir -p "$INSTALL_DIR"

exit 0
