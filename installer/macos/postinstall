#!/bin/bash
# Loxia Autopilot One - macOS Post-installation Script

set -e

INSTALL_DIR="/usr/local/lib/loxia"
BIN_DIR="/usr/local/bin"

# Ensure bin directory exists
mkdir -p "$BIN_DIR"

# Create symlink for the loxia command
ln -sf "$INSTALL_DIR/loxia" "$BIN_DIR/loxia"

# Make binary executable
chmod +x "$INSTALL_DIR/loxia"

# Verify installation
if [ -x "$BIN_DIR/loxia" ]; then
    echo "Loxia Autopilot One installed successfully!"
    echo ""
    echo "Available commands:"
    echo "  loxia web        - Start server and open Web UI"
    echo "  loxia terminal   - Start Terminal UI"
    echo "  loxia serve      - Start server only (headless)"
    echo "  loxia --help     - Show all commands"
    echo ""
    echo "To get started, run: loxia web"
else
    echo "Warning: Installation may not be complete. Please check manually."
    exit 1
fi

exit 0
